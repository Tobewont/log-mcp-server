# log-mcp-server environment variables.
# Copy to `.env` and customise. Comments mark default values.

# ---------------------------------------------------------------------------
# MCP transport
# ---------------------------------------------------------------------------
# MCP_TRANSPORT selects the transport. No auto-detection.
# Allowed values: "stdio" | "sse" | "streamable-http"
# MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1        # Use 0.0.0.0 for container/network exposure
# MCP_PORT=8000

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# LOG_BACKEND=loki           # Currently only "loki" is supported

# ---------------------------------------------------------------------------
# Loki backend
# ---------------------------------------------------------------------------
LOKI_ADDR=http://localhost:3100
# Multi-Loki (Thanos-style fan-out): pipe-separate the URLs.
# LOKI_ADDR=http://loki-bj:3100|http://loki-sh:3100|http://loki-sg:3100

# Single-tenant deployment uses "fake".
# Multi-tenant: pipe-separated, e.g. "team-a|team-b|team-c".
LOKI_TENANTS=fake

# ---------------------------------------------------------------------------
# Client-side tenant scope (REQUIRED for log-query tools)
# ---------------------------------------------------------------------------
# log-query tools (query_logs / get_labels / get_label_values) refuse to run
# unless the MCP client declares an explicit tenant subset.  Two ways:
#
#   * stdio mode: set LOKI_CLIENT_TENANTS in the env block of mcp.json
#     (subset of LOKI_TENANTS, comma-separated).
#   * streamable-http / sse mode: every MCP client request must carry an
#     ``X-Allowed-Tenants`` HTTP header (comma-separated).  The header
#     takes precedence over LOKI_CLIENT_TENANTS.
#
# health_check is exempt and remains available for diagnosis even when no
# scope is set.  Anything outside the allowed subset is rejected with a
# clear error.  This is defence-in-depth, NOT authentication.
#
# Performance note: only list the tenants you actually need. Tools called
# without an explicit tenant= fan out in parallel to every entry here, so
# more tenants == slower, noisier and less precise results.
# LOKI_CLIENT_TENANTS=team-a,team-b

# Authentication (pick at most one method).
# LOKI_USERNAME=your-username
# LOKI_PASSWORD=your-password
# LOKI_BEARER_TOKEN=your-bearer-token
# LOKI_BEARER_TOKEN_FILE=/path/to/token/file

# TLS
# LOKI_CA_FILE=/path/to/ca.crt
# LOKI_CERT_FILE=/path/to/client.crt
# LOKI_KEY_FILE=/path/to/client.key
# LOKI_TLS_SKIP_VERIFY=false

# HTTP timeouts (seconds)
# LOKI_CONNECT_TIMEOUT=10.0
# LOKI_READ_TIMEOUT=15.0
# LOKI_WRITE_TIMEOUT=10.0
# LOKI_POOL_TIMEOUT=10.0

# ---------------------------------------------------------------------------
# Health cache (multi-cluster only)
# ---------------------------------------------------------------------------
# Unhealthy clusters are automatically skipped for data queries.
# HEALTH_CHECK_INTERVAL=300   # background refresh interval (seconds)
# HEALTH_CHECK_TIMEOUT=5      # per-cluster probe timeout (seconds)

# ---------------------------------------------------------------------------
# Generic query / time settings (apply to all backends)
# ---------------------------------------------------------------------------
# LOG_DEFAULT_LIMIT=100
# LOG_MAX_LIMIT=5000
# LOG_DEFAULT_TIME_RANGE_MINUTES=30
# LOG_TIMEZONE=Asia/Shanghai

# ---------------------------------------------------------------------------
# Logging level for the server itself
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO             # DEBUG / INFO / WARNING / ERROR

# ---------------------------------------------------------------------------
# docker-compose only
# ---------------------------------------------------------------------------
# GRAFANA_PASSWORD=admin
