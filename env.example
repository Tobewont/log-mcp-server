# log-mcp-server 环境变量示例。
# 复制为 `.env` 后按需修改。注释里给出的是默认值。

# ---------------------------------------------------------------------------
# MCP 传输方式
# ---------------------------------------------------------------------------
# 通过 MCP_TRANSPORT 显式选择传输方式，不会自动推断。
# 可选值："stdio" | "sse" | "streamable-http"
# MCP_TRANSPORT=stdio
# 容器内/对外暴露时改为 0.0.0.0
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# ---------------------------------------------------------------------------
# 后端选择
# ---------------------------------------------------------------------------
# 目前仅支持 "loki"。
# LOG_BACKEND=loki

# ---------------------------------------------------------------------------
# Loki 后端
# ---------------------------------------------------------------------------
LOKI_ADDR=http://localhost:3100
# 多 Loki 实例（Thanos 风格扇出查询）：用 | 分隔多个 URL。
# LOKI_ADDR=http://loki-bj:3100|http://loki-sh:3100|http://loki-sg:3100

# 单租户部署使用 "fake"。
# 多租户：用 | 分隔，例如 "team-a|team-b|team-c"。
LOKI_TENANTS=fake

# ---------------------------------------------------------------------------
# 客户端租户范围（日志查询/下载工具必填）
# ---------------------------------------------------------------------------
# 日志查询 / 下载工具（query_logs / get_labels / get_label_values /
# download_logs）要求 MCP 客户端先声明可见租户子集，否则直接拒绝执行。
# 两种声明方式：
#
#   * stdio 模式：在 mcp.json 的 env 块中设置 LOKI_CLIENT_TENANTS
#     （LOKI_TENANTS 的子集，逗号分隔）。
#   * streamable-http / sse 模式：每个 MCP 客户端请求都必须携带
#     `X-Allowed-Tenants` HTTP 请求头（逗号分隔）。该请求头优先于
#     LOKI_CLIENT_TENANTS 环境变量。
#
# health_check 不受此限制，未声明范围时仍可调用，便于排查"为什么查不到"。
# 任何超出允许范围的租户都会被服务端直接拒绝。
# 这是纵深防御，不是身份认证。
#
# 性能提示：只列出实际需要的租户。未显式传 tenant= 时工具会并发查询
# 这里列出的所有租户，配的越多查询越慢、噪声越大、结果越不精准。
# LOKI_CLIENT_TENANTS=team-a,team-b

# ---------------------------------------------------------------------------
# 日志下载（download_logs 工具）
# ---------------------------------------------------------------------------
# stdio 模式：这就是用户本机文件系统（server 与 client 同进程），
#   工具返回的绝对路径直接可读。
# streamable-http / sse 模式：这是服务端文件系统（例如 pod 的 emptyDir），
#   服务端额外挂载 /<MCP前缀>/download/<token> 路由对外提供下载。
# LOG_DOWNLOAD_DIR=./logs/downloads
#
# 生成的文件（及对应的下载令牌）多久后被清理。仅 HTTP 模式生效。
# LOG_DOWNLOAD_TTL_SECONDS=3600
#
# HTTP 模式下用于渲染下载链接的可选 base URL。在反向代理改写 Host
# 的场景下显式设置；不设时服务端会根据请求的 scheme + Host 自动推断
# （并优先读取 X-Forwarded-Proto / X-Forwarded-Host）。
# LOG_DOWNLOAD_BASE_URL=https://logs-mcp.example.com

# 鉴权（最多选一种）。
# LOKI_USERNAME=your-username
# LOKI_PASSWORD=your-password
# LOKI_BEARER_TOKEN=your-bearer-token
# LOKI_BEARER_TOKEN_FILE=/path/to/token/file

# TLS
# LOKI_CA_FILE=/path/to/ca.crt
# LOKI_CERT_FILE=/path/to/client.crt
# LOKI_KEY_FILE=/path/to/client.key
# LOKI_TLS_SKIP_VERIFY=false

# HTTP 超时（秒）
# LOKI_CONNECT_TIMEOUT=10.0
# LOKI_READ_TIMEOUT=15.0
# LOKI_WRITE_TIMEOUT=10.0
# LOKI_POOL_TIMEOUT=10.0

# ---------------------------------------------------------------------------
# 健康检查缓存（仅多 Loki 集群时生效）
# ---------------------------------------------------------------------------
# 不健康的集群在数据查询时会被自动跳过。
# 后台刷新间隔（秒）
# HEALTH_CHECK_INTERVAL=300
# 单个集群健康探测超时（秒）
# HEALTH_CHECK_TIMEOUT=5

# ---------------------------------------------------------------------------
# 通用查询 / 时间相关参数（适用于所有后端）
# ---------------------------------------------------------------------------
# LOG_DEFAULT_LIMIT=100
# LOG_MAX_LIMIT=5000
# LOG_DEFAULT_TIME_RANGE_MINUTES=30
# LOG_TIMEZONE=Asia/Shanghai

# ---------------------------------------------------------------------------
# 服务自身的日志级别
# ---------------------------------------------------------------------------
# 可选值：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# 仅 docker-compose 用到
# ---------------------------------------------------------------------------
# GRAFANA_PASSWORD=admin
