# Loki MCP Server Environment Variables
# Copy this file to .env and customize the values

# FastMCP configuration (optional - FastMCP auto-detects mode)
# FASTMCP_DEBUG=false      # Enable debug mode
# FASTMCP_HOST=127.0.0.1   # Host for HTTP mode (when port specified)
# FASTMCP_PORT=8000        # Port for HTTP mode (omit for stdio mode)

# Loki server configuration
LOKI_ADDR=http://localhost:3100

# Multi-tenant configuration
# Single tenant (default)
LOKI_TENANTS=fake

# Multiple tenants (separated by |)
# LOKI_TENANTS=tenant1|tenant2|tenant3

# Authentication (choose one method)
# Basic authentication
# LOKI_USERNAME=your-username
# LOKI_PASSWORD=your-password

# Bearer token authentication
# LOKI_BEARER_TOKEN=your-bearer-token
# LOKI_BEARER_TOKEN_FILE=/path/to/token/file


# TLS settings
# LOKI_CA_FILE=/path/to/ca.crt
# LOKI_CERT_FILE=/path/to/client.crt
# LOKI_KEY_FILE=/path/to/client.key
# LOKI_TLS_SKIP_VERIFY=false

# HTTP client timeouts (in seconds)
# LOKI_CONNECT_TIMEOUT=10.0
# LOKI_READ_TIMEOUT=30.0
# LOKI_WRITE_TIMEOUT=10.0
# LOKI_POOL_TIMEOUT=10.0

# Query limits
# LOKI_DEFAULT_LIMIT=100
# LOKI_MAX_LIMIT=5000

# Default time range settings
# LOKI_DEFAULT_TIME_RANGE_MINUTES=30  # Default time range when start/end not specified

# Timezone settings
# LOKI_TIMEZONE=Asia/Shanghai  # Default timezone for time operations

# Grafana configuration (for docker-compose)
# GRAFANA_PASSWORD=admin
